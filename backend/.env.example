PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=gour_accounts

# Product registry bootstrap
# false (recommended): no default products are auto-created; register products via Admin UI/API.
# true  (dev convenience): inserts starter products (email-warmup, reach, sendflow) on startup.
SEED_DEFAULT_PRODUCTS=false

# JWT — change to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# CORS — static origins for the Accounts frontend itself.
# Product origins (warmup.gour.io, etc.) are loaded automatically from
# the product registry in the database (each product's redirect_urls field).
# You NEVER need to add product domains here — just register them via the
# admin API and CORS + redirect validation are handled automatically.
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redirect URI security ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (scheme+host) that may receive a
# signed JWT via a ?token= query parameter after login or product launch.
# Both POST /auth/login (redirect_uri body) and
# GET /api/v1/products/:name/launch?redirect_uri=... are validated against this.
# If a redirect_uri's origin is not in this list the request falls through to the
# normal dashboard response — no error is returned to the caller.
# Example:  http://localhost:3000,https://warmup.gour.io
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,https://yourapp.example.com

# Admin panel — required for /api/v1/admin/* routes (product registry management)
# Set to a long random string; keep secret. If unset, admin routes return 503.
ADMIN_SECRET=change-this-to-a-long-random-admin-secret

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys


# Leave blank to run without billing (Stripe routes return 503).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — from Stripe CLI or Dashboard > Webhooks
# stripe listen --forward-to localhost:8080/api/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ───────────────────────────────────────────────────────────
# Managed via Admin UI (Admin → Products → Edit). Do NOT set here.
# They are stored in the database and will not be overwritten on restart.
