# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

PORT=8080

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost          # use "db" inside Docker Compose
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=gour_accounts

# ── JWT / Auth ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ISSUER=accounts.gour.io
JWT_AUDIENCE=accounts.gour.io

# ── App environment & URLs ─────────────────────────────────────────────────────
APP_ENV=development                        # "production" on server
ACCOUNTS_BASE_URL=http://localhost:5173    # "https://accounts.gour.io" on server
APP_URL=http://localhost:5173              # "https://accounts.gour.io" on server

# ── CORS ───────────────────────────────────────────────────────────────────────
# Static origins for the Accounts frontend. Product origins are loaded
# automatically from the product registry — no need to add them here.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4000
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4000

# ── Redirect URI security ──────────────────────────────────────────────────────
# Origins allowed to receive a signed JWT via ?token= after login / product launch.
AUTH_REDIRECT_URIS=http://localhost:4000/auth/callback,http://localhost:3000/callback
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://localhost:4000

# ── Admin panel ────────────────────────────────────────────────────────────────
# Required for /api/v1/admin/* routes.  Use a long random string.
ADMIN_SECRET=change-this-to-a-long-random-admin-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

# ── Email (ZeptoMail SMTP relay) ───────────────────────────────────────────────
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASS=your_zepto_api_key
SMTP_FROM=noreply@yourdomain.com
SMTP_REPLY_TO=support@yourdomain.com

# ── Stripe (billing) ───────────────────────────────────────────────────────────
# Use sk_test_ / pk_test_ keys for development to avoid real charges.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — from: stripe listen --forward-to localhost:8080/api/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
