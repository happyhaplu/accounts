# Coolify — paste this entire file into your service's Environment Variables tab.
# This is identical to backend/.env with production URLs and docker-compose service names.

PORT=8080
APP_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# DB_HOST must be "db" — that is the postgres service name in docker-compose.yaml
DB_HOST=db
DB_PORT=5432
DB_USER=outcraftly
DB_PASSWORD=outcraftly
DB_NAME=accounts

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=gour-dev-secret-do-not-use-in-production
JWT_ISSUER=accounts.gour.io
JWT_AUDIENCE=accounts.gour.io

# ── Cross-app auth ────────────────────────────────────────────────────────────
ACCOUNTS_BASE_URL=https://accounts.gour.io
APP_URL=https://accounts.gour.io
AUTH_REDIRECT_URIS=http://localhost:4000/auth/callback,https://reach.gour.io/auth/callback,http://localhost:3000/callback,https://sendflow.gour.io/callback

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4000,https://accounts.gour.io,https://reach.gour.io,https://sendflow.gour.io
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4000,https://accounts.gour.io,https://reach.gour.io,https://sendflow.gour.io
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://localhost:4000,https://warmup.gour.io,https://reach.gour.io,https://sendflow.gour.io

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET=gour-admin-dev-secret
ADMIN_EMAIL=happy.outcraftly@zohomail.in
ADMIN_PASSWORD=System@123321

# ── Email (ZeptoMail SMTP relay) ──────────────────────────────────────────────
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASS=<copy from backend/.env>
SMTP_FROM=info@gridworkit.online
SMTP_REPLY_TO=happy.haplu@gmail.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=<copy from backend/.env>
STRIPE_SECRET_KEY=<copy from backend/.env>
STRIPE_WEBHOOK_SECRET=<copy from backend/.env>

# ── Coolify routing (Traefik) ─────────────────────────────────────────────────
# Traefik reads SERVICE_FQDN_FRONTEND to know which domain maps to the frontend container.
SERVICE_FQDN_FRONTEND=https://accounts.gour.io
# nginx inside the frontend container proxies /api/ to this internal URL — do not change.
BACKEND_URL=http://backend:8080
