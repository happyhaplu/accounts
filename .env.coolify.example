# ─────────────────────────────────────────────────────────────────────────────
# Coolify Environment Variables for accounts.gour.io
#
# HOW TO USE:
#   Coolify → your resource → Environment Variables tab → paste these lines.
#   Fill in every value marked with  ← CHANGE THIS
#   Leave everything else as-is unless you know what you're changing.
#
# DO NOT set BACKEND_URL — docker-start.sh hardcodes it to 127.0.0.1:8080
# (nginx and Go run inside the same container; "backend" hostname doesn't exist).
# ─────────────────────────────────────────────────────────────────────────────

PORT=8080
APP_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# DB_HOST MUST be "db" — that is the postgres service name in docker-compose.yaml
DB_HOST=db
DB_PORT=5432
DB_USER=gour
DB_PASSWORD=gour                            # ← CHANGE THIS in production
DB_NAME=accounts

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=gour-jwt-production-secret-change-me   # ← CHANGE THIS
JWT_ISSUER=accounts.gour.io
JWT_AUDIENCE=accounts.gour.io

# ── App URLs ──────────────────────────────────────────────────────────────────
ACCOUNTS_BASE_URL=https://accounts.gour.io
APP_URL=https://accounts.gour.io

# ── CORS ──────────────────────────────────────────────────────────────────────
# Only the accounts frontend URL itself needs to be here.
# Product domains (warmup.gour.io, reach.gour.io, etc.) are loaded
# AUTOMATICALLY from the product registry in the database — no env change
# needed when you register a new product via the Admin UI.
CORS_ALLOWED_ORIGINS=https://accounts.gour.io
ALLOW_ORIGINS=https://accounts.gour.io

# ── Redirect URI security ─────────────────────────────────────────────────────
# These are also NOT needed once products are registered.
# Each product's redirect_urls in the DB are checked automatically at runtime.
# Leave both blank — add them only if a product redirect breaks and you need
# a quick override without redeploying.
AUTH_REDIRECT_URIS=
ALLOWED_REDIRECT_ORIGINS=

# ── Admin panel ───────────────────────────────────────────────────────────────
# Use a long random string:  openssl rand -hex 24
ADMIN_SECRET=gour-admin-secret-change-me          # ← CHANGE THIS
ADMIN_EMAIL=happy.outcraftly@zohomail.in           # ← your admin login email
ADMIN_PASSWORD=System@123321                       # ← CHANGE THIS

# ── Email (ZeptoMail SMTP relay) ──────────────────────────────────────────────
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASS=                                         # ← paste your ZeptoMail API key
SMTP_FROM=info@gridworkit.online
SMTP_REPLY_TO=happy.haplu@gmail.com

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                                 # ← sk_live_... from Stripe dashboard
STRIPE_PUBLISHABLE_KEY=                            # ← pk_live_... from Stripe dashboard
STRIPE_WEBHOOK_SECRET=                             # ← whsec_... from Stripe webhook settings

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Do NOT set these here. Manage them via Admin UI → Products → Edit.
# They are stored in the database and survive restarts without env vars.
