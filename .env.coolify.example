# ── Gour Accounts — Coolify Production Environment ──────────────────────
# Copy this to your Coolify app's environment variables panel.

APP_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=outcraftly
DB_PASSWORD=CHANGE-ME
DB_NAME=accounts

# ── JWT / Cross-app auth ─────────────────────────────────────────────────────
# All tokens carry: sub, exp, iss, aud, role
JWT_SECRET=CHANGE-ME-STRONG-SECRET
JWT_ISSUER=accounts.gour.io
JWT_AUDIENCE=reach

# Optional: RS256 asymmetric keys (leave blank to use HS256 shared secret)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWKS_URL=https://accounts.gour.io/.well-known/jwks.json

ACCOUNTS_BASE_URL=https://accounts.gour.io

# Allowed redirect callback URIs (comma-separated, exact match)
AUTH_REDIRECT_URIS=http://localhost:4000/auth/callback,https://reach.gour.io/auth/callback

# CORS — all origins that may call the Accounts API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4000,https://accounts.gour.io,https://warmup.gour.io,https://reach.gour.io

# Legacy redirect-origin allowlist (scheme://host only)
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://localhost:4000,https://warmup.gour.io,https://reach.gour.io

# ── Admin API ─────────────────────────────────────────────────────────────────
ADMIN_SECRET=CHANGE-ME-ADMIN-SECRET

# ── Email (ZeptoMail SMTP relay) ─────────────────────────────────────────────
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASS=CHANGE-ME
SMTP_FROM=info@gridworkit.online
SMTP_REPLY_TO=happy.haplu@gmail.com

# Frontend URL — used in email links
APP_URL=https://accounts.gour.io

# ── Stripe (billing) — use LIVE keys in production ───────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Per-product Stripe Price IDs ─────────────────────────────────────────────
STRIPE_EMAIL_WARMUP_PRICE_ID=price_...
STRIPE_REACH_PRICE_ID=price_...
